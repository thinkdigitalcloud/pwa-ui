{
  "name": "@thinkdigitalcloud/pwa-ui",
  "version": "0.1.18",
  "description": "Shared React 18 + TypeScript component library extracted from the TDD PWA estate apps (anch, balwin, gocity, redefine).",
  "license": "MIT",
  "author": "TDD Games",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "react",
    "react18",
    "typescript",
    "component-library",
    "storybook",
    "styled-components",
    "pwa",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thinkdigitalcloud/pwa-ui.git"
  },
  "homepage": "https://github.com/thinkdigitalcloud/pwa-ui#readme",
  "bugs": {
    "url": "https://github.com/thinkdigitalcloud/pwa-ui/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepare": "tsup",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "styled-components": "^6.0.0"
  },
  "dependencies": {
    "react-icons": "^5.3.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.3.5",
    "@storybook/addon-interactions": "^8.3.5",
    "@storybook/blocks": "^8.3.5",
    "@storybook/react": "^8.3.5",
    "@storybook/react-vite": "^8.3.5",
    "@storybook/test": "^8.3.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.3.5",
    "styled-components": "^6.1.13",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
